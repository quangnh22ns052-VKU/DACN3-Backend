# ============================================
# DATABASE CONFIGURATION
# ============================================
# Local development
DATABASE_URL=postgresql://user:password@localhost:5432/phishguard?sslmode=disable
# Production (Neon, AWS RDS, etc)
# DATABASE_URL=postgresql://user:password@host:5432/phishguard?sslmode=require

DB_POOL_SIZE=20
DB_ECHO=false

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# API CONFIGURATION
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WORKERS=4

# ============================================
# CORS & FRONTEND
# ============================================
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://frontend:8501
FRONTEND_URL=http://localhost:8501

# ============================================
# THREAT INTELLIGENCE APIs (Optional)
# ============================================
GSB_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# ============================================
# ML MODEL CONFIGURATION
# ============================================
MODEL_PATH=./models/tfidf_lr.pkl
CONFIDENCE_THRESHOLD=0.5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
# production | staging | development
