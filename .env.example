# =====================================================
# DATABASE CONFIGURATION (Required)
# =====================================================
# LOCAL: Use PostgreSQL local or Docker postgres:15
# Example: postgresql://user:password@localhost:5432/phishguard?sslmode=disable
# 
# CLOUD (Render): Use Neon PostgreSQL from https://console.neon.tech/
# Example: postgresql://user:password@ep-xxx.us-west-2.neon.tech:5432/phishguard?sslmode=require
#
# Get Neon URL: Project Settings → Connection string → Pooling
DATABASE_URL=postgresql://user:password@localhost:5432/phishguard?sslmode=disable

# Connection Pool Settings (Cloud production: increase values)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_ECHO=false

# =====================================================
# SECURITY & AUTHENTICATION (Required for production)
# =====================================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =====================================================
# ENVIRONMENT SETTING
# =====================================================
# LOCAL: development | CLOUD: production
ENVIRONMENT=development

# =====================================================
# API CONFIGURATION
# =====================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

# =====================================================
# CLOUD DEPLOYMENT URLs (Set for cloud only)
# =====================================================
# Render: https://service-name-xxxx.onrender.com
# AWS AppRunner: https://service-name-xxxx.us-east-1.cs.amazonapprunner.com
RENDER_EXTERNAL_URL=
APPRUNNER_URL=
API_BASE_URL=http://localhost:8000

# =====================================================
# FRONTEND URL (For CORS)
# =====================================================
# LOCAL: http://localhost:8501
# CLOUD: https://phishguard-frontend-xxxx.onrender.com
FRONTEND_URL=http://localhost:8501
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://frontend:8501

# =====================================================
# THREAT INTELLIGENCE APIs (Optional for scanning)
# =====================================================
# Get keys from:
# - VirusTotal: https://www.virustotal.com/gui/home/upload
# - Google Safe Browsing: https://developers.google.com/safe-browsing/v4/get-started
# - AbuseIPDB: https://www.abuseipdb.com/
VIRUSTOTAL_API_KEY=your_virustotal_api_key
GSB_API_KEY=your_google_safe_browsing_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key

# =====================================================
# ML MODEL CONFIGURATION
# =====================================================
MODEL_PATH=./models/tfidf_lr.pkl
CONFIDENCE_THRESHOLD=0.5

# =====================================================
# LOGGING
# =====================================================
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/phishguard.log

# =====================================================
# WORKER CONFIGURATION (For production)
# =====================================================
# Render/AWS will auto-set based on CPU
# WORKERS=4

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
# production | staging | development
